---
interface Item { q: string; a: string }
interface Props { items: Item[]; class?: string }
const { items, class: className = "" } = Astro.props;
---

<div class={`divide-y divide-(--color-line) border-y border-(--color-line) ${className}`}>
  {items.map((item) => (
    <details class="group py-5">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left font-display text-base font-semibold text-(--color-paper) marker:content-none">
        <span>{item.q}</span>
        <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-(--color-line) text-(--color-mist) transition-transform group-open:rotate-45">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M6 1V11M1 6H11" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
          </svg>
        </span>
      </summary>
      <p class="mt-3 max-w-3xl text-sm leading-relaxed text-(--color-mist)" set:html={item.a}></p>
    </details>
  ))}
</div>
