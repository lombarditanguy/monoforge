---
import { NAV, SITE } from "../data/site.js";
const current = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-(--color-line) bg-(--color-ink)/90 backdrop-blur">
  <div class="container-mf flex h-16 items-center justify-between md:h-20">
    <a href="/" class="flex items-center gap-2 font-display text-lg font-bold tracking-tight text-(--color-paper)">
      <svg width="28" height="28" viewBox="0 0 32 32" aria-hidden="true">
        <circle cx="16" cy="16" r="14.6" fill="none" stroke="var(--color-surface-2)" stroke-width="2.4" />
        <circle cx="16" cy="16" r="13.4" fill="none" stroke="var(--color-mist)" stroke-width="1.4" />
        <g fill="var(--color-paper)">
          <polygon points="14.42,12.76 14.03,3.56 17.97,3.56 17.58,12.76" />
          <polygon points="18.59,13.5 27.23,10.28 28.44,14.03 19.56,16.5" />
          <polygon points="19.18,17.69 24.91,24.91 21.72,27.23 16.63,19.55" />
          <polygon points="15.37,19.55 10.28,27.23 7.09,24.91 12.82,17.69" />
          <polygon points="12.44,16.5 3.56,14.03 4.77,10.28 13.41,13.5" />
        </g>
        <circle cx="16" cy="16" r="4.6" fill="var(--color-ink)" stroke="var(--color-forge-500)" stroke-width="2.6" />
        <g fill="var(--color-forge-400)">
          <circle cx="19.29" cy="11.47" r="0.9" />
          <circle cx="21.33" cy="17.73" r="0.9" />
          <circle cx="16" cy="21.6" r="0.9" />
          <circle cx="10.67" cy="17.73" r="0.9" />
          <circle cx="12.71" cy="11.47" r="0.9" />
        </g>
      </svg>
      <span>MONO<span class="text-(--color-forge-400)">FORGE</span></span>
    </a>

    <nav aria-label="Navigation principale" class="hidden lg:block">
      <ul class="flex items-center gap-8">
        {NAV.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                "text-sm font-medium transition-colors",
                current.startsWith(item.href) ? "text-(--color-forge-400)" : "text-(--color-mist) hover:text-(--color-paper)",
              ]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="hidden items-center gap-4 lg:flex">
      <a href="/contact" class="text-sm font-medium text-(--color-mist) hover:text-(--color-paper)">Contact</a>
      <a href="/configurateur" class="btn btn-forge">Démarrer un projet</a>
    </div>

    <button
      id="mf-nav-toggle"
      type="button"
      class="flex h-10 w-10 items-center justify-center border border-(--color-line) text-(--color-paper) lg:hidden"
      aria-expanded="false"
      aria-controls="mf-mobile-nav"
      aria-label="Ouvrir le menu"
    >
      <svg id="mf-nav-icon-open" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M1 3H17M1 9H17M1 15H17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
      <svg id="mf-nav-icon-close" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true" class="hidden">
        <path d="M2 2L16 16M16 2L2 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <div id="mf-mobile-nav" class="hidden border-t border-(--color-line) lg:hidden">
    <div class="container-mf flex flex-col gap-1 py-4">
      {NAV.map((item) => (
        <a href={item.href} class="rounded px-2 py-3 text-base font-medium text-(--color-paper) hover:bg-(--color-surface)">
          {item.label}
        </a>
      ))}
      <a href="/contact" class="rounded px-2 py-3 text-base font-medium text-(--color-paper) hover:bg-(--color-surface)">Contact</a>
      <a href="/configurateur" class="btn btn-forge mt-2 w-full">Démarrer un projet</a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("mf-nav-toggle");
  const menu = document.getElementById("mf-mobile-nav");
  const iconOpen = document.getElementById("mf-nav-icon-open");
  const iconClose = document.getElementById("mf-nav-icon-close");

  toggle?.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!expanded));
    menu?.classList.toggle("hidden");
    iconOpen?.classList.toggle("hidden");
    iconClose?.classList.toggle("hidden");
    toggle.setAttribute("aria-label", expanded ? "Ouvrir le menu" : "Fermer le menu");
  });
</script>
