---
interface Props { item: any }
const { item } = Astro.props;
---

<a href={`/catalogue/${item.family}/${item.slug}`} class="group block overflow-hidden rounded-lg border border-(--color-line) bg-(--color-surface) transition-colors hover:border-(--color-forge-500)/60">
  <div class="aspect-square overflow-hidden bg-(--color-surface-2)">
    <img
      src={item.image}
      alt={`Jante forgée ${item.code}`}
      loading="lazy"
      width="300"
      height="300"
      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
    />
  </div>
  <p class="px-3 py-2.5 text-center font-display text-sm font-bold text-(--color-paper)">{item.code}</p>
</a>
