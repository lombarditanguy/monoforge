---
interface Props { item: any }
const { item } = Astro.props;
---

<a
  href={`/catalogue/${item.family}/${item.slug}`}
  data-wheel-code={item.code.toLowerCase()}
  data-wheel-color={item.color || ""}
  class="wheel-card group block overflow-hidden rounded-lg border border-(--color-line) bg-(--color-surface) transition-all duration-300 hover:-translate-y-1 hover:border-(--color-forge-500)/60 hover:shadow-[0_16px_32px_-12px_rgba(0,0,0,0.55)]"
>
  <div class="relative aspect-square overflow-hidden bg-(--color-surface-2)">
    <img
      src={item.image}
      alt={`Jante forgée ${item.code}`}
      loading="lazy"
      width="300"
      height="300"
      class="h-full w-full object-cover transition-transform duration-300 ease-out group-hover:scale-[1.06]"
    />
    <div class="pointer-events-none absolute inset-x-0 bottom-0 h-14 bg-gradient-to-t from-(--color-ink)/90 to-transparent opacity-0 transition-opacity duration-200 group-hover:opacity-100"></div>
    <span class="pointer-events-none absolute bottom-2.5 left-1/2 flex -translate-x-1/2 items-center gap-1 text-xs font-semibold text-(--color-forge-400) opacity-0 transition-opacity duration-200 group-hover:opacity-100">
      Voir la fiche
      <svg width="10" height="10" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7H13M13 7L8 2M13 7L8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
    </span>
  </div>
  <p class="px-3 py-2.5 text-center font-display text-sm font-bold text-(--color-paper)">{item.code}</p>
</a>
