---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CTASection from "../../components/CTASection.astro";
import { articles } from "../../data/articles.js";
import { breadcrumbLd } from "../../utils/seo.js";

const dateFmt = (d) => new Date(d).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" });
---

<Layout
  title="Journal — Guides sur les jantes forgées sur mesure"
  description="Forgeage vs coulée, choix des tailles, monobloc ou multi-pièces, délais : les guides MONOFORGE pour comprendre les jantes forgées sur mesure avant de se lancer."
  jsonLd={breadcrumbLd([{ name: "Journal", path: "/journal" }])}
>
  <Breadcrumbs items={[{ name: "Journal", path: "/journal" }]} />

  <section class="container-mf pb-16 pt-6">
    <p class="chip">Guides &amp; explications</p>
    <h1 class="mt-6 max-w-2xl text-balance font-display text-4xl font-bold leading-tight text-(--color-paper) sm:text-5xl">
      Le journal MONOFORGE
    </h1>
    <p class="mt-5 max-w-xl text-balance text-lg leading-relaxed text-(--color-mist)">
      Des guides techniques, sans jargon inutile, pour comprendre le forgeage, choisir vos tailles et savoir à quoi vous attendre avant de démarrer un projet.
    </p>
  </section>

  <section class="container-mf grid grid-cols-1 gap-6 pb-24 md:grid-cols-2">
    {articles.map((article) => (
      <a href={`/journal/${article.slug}`} class="card-mf flex flex-col p-8 transition-colors hover:border-(--color-forge-500)/60">
        <p class="text-xs uppercase tracking-widest text-(--color-fog)">{dateFmt(article.date)} · {article.readingTime} de lecture</p>
        <h2 class="mt-3 font-display text-xl font-bold text-(--color-paper)">{article.title}</h2>
        <p class="mt-3 flex-1 text-sm leading-relaxed text-(--color-mist)">{article.excerpt}</p>
        <span class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-(--color-forge-400)">
          Lire l'article
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7H13M13 7L8 2M13 7L8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </a>
    ))}
  </section>

  <CTASection
    title="Prêt à passer du guide au projet ?"
    description="Étude technique gratuite, sans engagement."
  />
</Layout>
