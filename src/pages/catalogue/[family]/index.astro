---
import Layout from "../../../layouts/Layout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import WheelPhotoCard from "../../../components/WheelPhotoCard.astro";
import CTASection from "../../../components/CTASection.astro";
import { FAMILIES, itemsForFamily } from "../../../data/catalog.js";
import { breadcrumbLd } from "../../../utils/seo.js";

export function getStaticPaths() {
  return FAMILIES.map((family) => ({
    params: { family: family.slug },
    props: { family },
  }));
}

const { family } = Astro.props;
const items = itemsForFamily(family.slug);

const COLOR_GROUPS = [
  { label: "Noir", swatch: "#141414", tags: ["noir"] },
  { label: "Anthracite", swatch: "#42424a", tags: ["anthracite"] },
  { label: "Gris", swatch: "#9a9a96", tags: ["gris"] },
  { label: "Argent", swatch: "#dcdcd8", tags: ["argent"] },
  { label: "Bronze / or", swatch: "#ab7a3f", tags: ["bronze", "or", "orange"] },
  { label: "Rouge", swatch: "#b5342a", tags: ["rouge"] },
  { label: "Bleu", swatch: "#3a5f8a", tags: ["bleu"] },
];
const availableGroups = COLOR_GROUPS.map((g) => ({
  ...g,
  count: items.filter((i) => g.tags.includes(i.color)).length,
})).filter((g) => g.count > 0);
---

<Layout
  title={`${family.label} — ${items.length} références de jantes forgées`}
  description={`${family.description} ${items.length} références en photo, fabriquées à la commande, toute taille sur demande.`}
  jsonLd={breadcrumbLd([{ name: "Catalogue", path: "/catalogue" }, { name: family.short, path: `/catalogue/${family.slug}` }])}
>
  <Breadcrumbs items={[{ name: "Catalogue", path: "/catalogue" }, { name: family.short, path: `/catalogue/${family.slug}` }]} />

  <section class="container-mf pb-12 pt-6">
    <p class="chip">{items.length} références</p>
    <h1 class="mt-6 max-w-2xl text-balance font-display text-4xl font-bold leading-tight text-(--color-paper) sm:text-5xl">
      {family.label}
    </h1>
    <p class="mt-5 max-w-2xl text-balance text-lg leading-relaxed text-(--color-mist)">{family.description}</p>
    <div class="mt-6 rounded-lg border border-(--color-forge-500)/30 bg-(--color-forge-500)/5 p-4 text-sm leading-relaxed text-(--color-mist)">
      <strong class="text-(--color-paper)">Aucune taille affichée ici volontairement.</strong> Ces photos montrent le dessin, pas un format figé : diamètre, largeur et déport sont définis avec vous au moment de la commande. Aucun stock — chaque jeu est fabriqué spécialement pour votre véhicule.
    </div>
  </section>

  <section class="container-mf pb-10">
    {availableGroups.length > 1 && (
      <div class="mb-7">
        <p class="mb-3 text-xs uppercase tracking-widest text-(--color-fog)">Filtrer par finition</p>
        <div id="mf-color-filters" class="flex flex-wrap items-center gap-2">
          <button
            type="button"
            data-color-filter=""
            class="mf-color-chip is-active flex items-center gap-2 rounded-full border border-(--color-forge-500) bg-(--color-forge-500)/10 px-3.5 py-1.5 text-xs font-semibold text-(--color-paper) transition-colors"
          >
            Toutes
            <span class="text-(--color-fog)">{items.length}</span>
          </button>
          {availableGroups.map((g) => (
            <button
              type="button"
              data-color-filter={g.tags.join(",")}
              class="mf-color-chip flex items-center gap-2 rounded-full border border-(--color-line) bg-(--color-surface-2) px-3.5 py-1.5 text-xs font-semibold text-(--color-mist) transition-colors hover:border-(--color-forge-500)/50"
            >
              <span class="h-3 w-3 rounded-full border border-white/15" style={`background:${g.swatch}`}></span>
              {g.label}
              <span class="text-(--color-fog)">{g.count}</span>
            </button>
          ))}
        </div>
      </div>
    )}
    <p id="mf-catalog-count" class="mb-4 text-sm text-(--color-fog)">{items.length} références affichées</p>
    <div id="mf-catalog-grid" class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
      {items.map((item) => <WheelPhotoCard item={item} />)}
    </div>
    <p id="mf-catalog-empty" class="hidden py-16 text-center text-sm text-(--color-fog)">Aucune référence dans cette finition pour l'instant.</p>
  </section>

  <script define:vars={{ total: items.length }}>
    const chips = Array.from(document.querySelectorAll("#mf-color-filters .mf-color-chip"));
    const grid = document.getElementById("mf-catalog-grid");
    const count = document.getElementById("mf-catalog-count");
    const empty = document.getElementById("mf-catalog-empty");
    if (grid) {
      const cards = Array.from(grid.querySelectorAll("[data-wheel-color]"));
      chips.forEach((chip) => {
        chip.addEventListener("click", () => {
          const tags = chip.dataset.colorFilter ? chip.dataset.colorFilter.split(",") : null;
          let visible = 0;
          for (const card of cards) {
            const match = !tags || tags.includes(card.dataset.wheelColor);
            card.classList.toggle("hidden", !match);
            if (match) visible += 1;
          }
          chips.forEach((c) => {
            c.classList.toggle("is-active", c === chip);
            c.classList.toggle("border-(--color-forge-500)", c === chip);
            c.classList.toggle("bg-(--color-forge-500)/10", c === chip);
            c.classList.toggle("text-(--color-paper)", c === chip);
            c.classList.toggle("border-(--color-line)", c !== chip);
            c.classList.toggle("bg-(--color-surface-2)", c !== chip);
            c.classList.toggle("text-(--color-mist)", c !== chip);
          });
          if (count) count.textContent = tags ? `${visible} / ${total} références` : `${total} références affichées`;
          if (empty) empty.classList.toggle("hidden", visible !== 0);
          grid.classList.toggle("hidden", visible === 0);
        });
      });
    }
  </script>

  <CTASection
    title={`Une référence ${family.short} vous plaît ?`}
    description="Indiquez sa référence dans le configurateur : nous l'adaptons à la taille et au déport de votre véhicule."
  />
</Layout>
