---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import FamilyCard from "../../components/FamilyCard.astro";
import CTASection from "../../components/CTASection.astro";
import { FAMILIES, catalogItems } from "../../data/catalog.js";
import { breadcrumbLd } from "../../utils/seo.js";
---

<Layout
  title="Catalogue de jantes forgées — plus de 290 références"
  description={`Plus de ${catalogItems.length} références de jantes forgées (monobloc, multi-pièces, tout-terrain, poids lourd), avec photo et code fournisseur. Chaque dessin est adaptable à toute taille sur demande.`}
  jsonLd={breadcrumbLd([{ name: "Catalogue", path: "/catalogue" }])}
>
  <Breadcrumbs items={[{ name: "Catalogue", path: "/catalogue" }]} />

  <section class="container-mf pb-16 pt-6">
    <p class="chip">{catalogItems.length} références en photo</p>
    <h1 class="mt-6 max-w-2xl text-balance font-display text-4xl font-bold leading-tight text-(--color-paper) sm:text-5xl">
      Le catalogue MONOFORGE
    </h1>
    <p class="mt-5 max-w-2xl text-balance text-lg leading-relaxed text-(--color-mist)">
      Ces <strong class="text-(--color-paper)">{catalogItems.length} références</strong>, organisées en 4 familles, sont un aperçu de ce que notre atelier partenaire sait forger — <strong class="text-(--color-paper)">pas un stock</strong>. Chaque jante est fabriquée à la commande, dans la taille et le déport définis pour votre véhicule, et le dessin lui-même peut être adapté sur demande.
    </p>
  </section>

  <section class="container-mf pb-10">
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {FAMILIES.map((family) => <FamilyCard family={family} />)}
    </div>
  </section>

  <CTASection
    eyebrow="Aucune de ces références ne convient tel quel ?"
    title="Partez d'une feuille blanche avec notre bureau technique."
    description="Décrivez votre projet : nous dessinons une jante inédite, taillée pour votre véhicule."
    primaryHref="/configurateur"
    primaryLabel="Démarrer un projet inédit"
    secondaryHref="/sur-mesure"
    secondaryLabel="Comprendre le sur-mesure"
  />
</Layout>
